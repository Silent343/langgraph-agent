# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values for LOCAL development.
# Never commit .env to version control.
#
#   cp .env.example .env
#
# For Railway (production), add these variables in the Railway dashboard
# under your service → Variables tab. Do NOT upload .env to Railway.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key — get one FREE at https://console.groq.com
# No credit card required. Works in Peru / LATAM without quota issues.
GROQ_API_KEY=your_groq_api_key_here

# DATABASE_URL — only needed locally if you want to test with Postgres.
# On Railway this is injected automatically when you add the Postgres plugin.
# Leave this blank for local development (SQLite will be used instead).
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_db
